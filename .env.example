# ========================================================
# CONFIGURATION DJANGO - Plateforme Gestion Locative
# ========================================================

# *** SÉCURITÉ ***
DEBUG=False
SECRET_KEY=django-insecure-CHANGE_THIS_IN_PRODUCTION_TO_RANDOM_SECRET
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# *** BASE DE DONNÉES - DÉVELOPPEMENT ***
# SQLite (développement au local)
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3

# *** BASE DE DONNÉES - PRODUCTION ***
# Décommenter pour PostgreSQL en production
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=immobilier_prod
# DB_USER=postgres
# DB_PASSWORD=your_secure_password
# DB_HOST=db.example.com
# DB_PORT=5432

# *** REDIS (Cache et Celery) ***
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
CELERY_BROKER_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0

# *** EMAIL (Facturation Automatique) ***
# Console (développement - emails affichés en console)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Gmail (production)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your_email@gmail.com
# EMAIL_HOST_PASSWORD=your_app_password

# SendGrid (alternative)
# EMAIL_BACKEND=sendgrid_backend.SendgridBackend
# SENDGRID_API_KEY=your_sendgrid_key

# *** SMS (Notifications Paiements) ***
# Twilio
SMS_PROVIDER=twilio
SMS_ACCOUNT_SID=your_twilio_account_sid
SMS_AUTH_TOKEN=your_twilio_auth_token
SMS_PHONE_NUMBER=+1234567890

# *** CELERY (Tâches Programmées) ***
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_ENABLED=True

# *** PAIEMENTS EN LIGNE (Optionnel) ***
# Stripe
STRIPE_PUBLIC_KEY=pk_test_XXXXXXXX
STRIPE_SECRET_KEY=sk_test_XXXXXXXX

# Wave (AfricaMultiplier)
WAVE_API_KEY=your_wave_api_key
WAVE_MERCHANT_ID=your_wave_merchant_id

# *** FICHIERS & MÉDIAS ***
MEDIA_ROOT=media/
MEDIA_URL=/media/
MAX_UPLOAD_SIZE=10485760  # 10MB

# *** AWS S3 (Stockage Production) ***
# USE_S3=True
# AWS_ACCESS_KEY_ID=your_aws_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret
# AWS_STORAGE_BUCKET_NAME=immobilier-prod
# AWS_S3_REGION_NAME=eu-west-1

# *** LOGS ***
LOG_LEVEL=INFO
LOG_FILE=logs/immobilier.log

# *** SENTRY (Error Tracking) ***
# SENTRY_DSN=https://your_key@sentry.io/your_project_id

# *** CORS ***
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://yourdomain.com

# *** FRONTEND ***
FRONTEND_URL=http://localhost:3000

# *** TIMEZONE ***
TIME_ZONE=Africa/Abidjan

# *** API ***
API_PAGINATION_SIZE=10
API_MAX_LIMIT=1000

# *** SÉCURITÉ SUPPLÉMENTAIRE ***
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# Pour production:
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# SECURE_HSTS_PRELOAD=True
SMS_AUTH_TOKEN=

# API
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Celery (pour la facturation automatique)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Localisation
LANGUAGE_CODE=fr-FR
TIME_ZONE=Africa/Abidjan
