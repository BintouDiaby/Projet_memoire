# ==========================================================================
#  ImmoGérer — variables d'environnement pour le déploiement Docker
#  Copier ce fichier en `.env` SUR LA VM et remplir les valeurs.
#  Le .env n'est JAMAIS mis dans l'image ni commité (voir .gitignore / .dockerignore).
#  Seules les variables ci-dessous sont réellement lues par settings.py.
# ==========================================================================

# --- Image Docker Hub (remplace "toncompte" par ton identifiant Docker Hub) ---
IMAGE_NAME=toncompte/immogerer
IMAGE_TAG=latest

# --- Sécurité ---
# Générer une clé unique, ex :
#   python -c "from django.core.management.utils import get_random_secret_key as k; print(k())"
SECRET_KEY=CHANGE_MOI_par_une_cle_secrete_unique
DEBUG=False
# IP de la VM + domaine éventuel (séparés par des virgules, sans espace)
ALLOWED_HOSTS=34.77.243.188,127.0.0.1,localhost

# --- Base de données PostgreSQL (dans le conteneur "db") ---
DB_ENGINE=django.db.backends.postgresql
DB_NAME=immogerer
DB_USER=immogerer_user
DB_PASSWORD=CHANGE_MOI_mot_de_passe_solide
DB_HOST=db
DB_PORT=5432

# --- Celery / Redis (dans le conteneur "redis") ---
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# --- CORS / CSRF ---
# CORS : inutile pour l'app mobile native (JWT). À remplir seulement si tu as un
# front web (Flutter Web) sur un domaine précis. Ex : https://mon-site.com
CORS_ALLOWED_ORIGINS=
# CSRF : nécessaire pour les POST du SITE WEB en HTTPS (une fois le domaine + SSL en place)
# Ex : https://mon-domaine.com
CSRF_TRUSTED_ORIGINS=

# --- Email (OTP / confirmation de compte). Laisser en console si non configuré. ---
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# Pour de vrais emails (Gmail SMTP p.ex.) :
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=ton_email@gmail.com
# EMAIL_HOST_PASSWORD=mot_de_passe_application
# DEFAULT_FROM_EMAIL=ImmoGérer <noreply@immogerer.ci>

# --- Stripe (paiement carte) — optionnel, laisser vide si non utilisé ---
STRIPE_SECRET_KEY=

# --- FNE (Facture Normalisée Électronique DGI Côte d'Ivoire) — optionnel ---
# Tant que FNE_API_KEY est vide, la certification est ignorée (aucun appel réseau).
FNE_API_URL=http://54.247.95.108/ws
FNE_API_KEY=
